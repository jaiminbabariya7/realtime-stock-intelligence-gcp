# ── GCP ──────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# ── Alpaca Markets ────────────────────────────────────────────────────────────
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_SECRET_KEY=your-alpaca-secret-key

# ── Pub/Sub ───────────────────────────────────────────────────────────────────
PUBSUB_TOPIC=stock-price-events
PUBSUB_SUB=dataflow-stock-sub

# ── BigQuery ──────────────────────────────────────────────────────────────────
BQ_DATASET=stock_data

# ── GCS (model storage) ───────────────────────────────────────────────────────
MODEL_BUCKET=your-gcp-project-id-models

# ── ML ────────────────────────────────────────────────────────────────────────
SEQ_LEN=20
ARIMA_P=5
ARIMA_D=1
ARIMA_Q=0
TEST_SPLIT=0.1

# ── Symbols to stream (comma-separated) ──────────────────────────────────────
WATCH_SYMBOLS=AAPL,TSLA,NVDA,MSFT,GOOGL,AMZN,META,NFLX

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_DEBUG=false
PORT=8080
HISTORY_LIMIT=200

# ── Dataflow ──────────────────────────────────────────────────────────────────
DATAFLOW_REGION=us-central1
